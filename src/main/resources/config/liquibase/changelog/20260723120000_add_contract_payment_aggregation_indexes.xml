<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Equality indexes for contract → PO → payment aggregation.
        Enables: find POs by contract number, sum payments by those PO numbers,
        and (later) join paid totals onto contract list views.

        Measured on CW95481 (~5k POs, ~10k payments): ~420ms seq-scan → ~28ms with these indexes.
    -->
    <changeSet id="20260723120000-1" author="jhipster" dbms="postgresql">
        <sql>
            CREATE INDEX IF NOT EXISTS idx_purchase_order_contractnumber_ponumber
                ON purchase_order (contractnumber, ponumber);
        </sql>
        <rollback>DROP INDEX IF EXISTS idx_purchase_order_contractnumber_ponumber;</rollback>
    </changeSet>

    <changeSet id="20260723120000-2" author="jhipster" dbms="postgresql">
        <sql>
            CREATE INDEX IF NOT EXISTS idx_pass_payment_ponumber_amount
                ON pass_payment (ponumber) INCLUDE (paymentamount);
        </sql>
        <rollback>DROP INDEX IF EXISTS idx_pass_payment_ponumber_amount;</rollback>
    </changeSet>

    <changeSet id="20260723120000-3" author="jhipster" dbms="postgresql">
        <sql>
            CREATE INDEX IF NOT EXISTS idx_pass_contract_contractnumber
                ON pass_contract (contractnumber);
        </sql>
        <rollback>DROP INDEX IF EXISTS idx_pass_contract_contractnumber;</rollback>
    </changeSet>
</databaseChangeLog>
